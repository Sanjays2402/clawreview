    "@clawreview/diff": "workspace:*",
    "@clawreview/llm": "workspace:*",
    "@clawreview/types": "workspace:*",
    "envalid": "^8.0.0",
    "kleur": "^4.1.5",
    "yaml": "^2.6.0"
  },
  "devDependencies": {
    "@types/node": "^25.9.1",
    "tsx": "^4.19.2",
    "typescript": "^6.0.3",
    "vitest": "^4.1.8"
  }
}
