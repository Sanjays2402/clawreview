{
  "name": "@clawreview/cli",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "bin": {
    "clawreview": "./src/index.ts"
  },
  "scripts": {
    "start": "tsx src/index.ts",
    "build": "tsc -p tsconfig.json",
    "typecheck": "tsc --noEmit -p tsconfig.json",
    "test": "vitest run"
  },
  "dependencies": {
    "@clawreview/agents": "workspace:*",
